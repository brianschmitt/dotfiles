#!/usr/bin/env sh

# chpwd() {
#     ll
# }

# env management >>>
ENVFILE_ROOT=~/.secrets

oc() {
    # open claude with preferred model
    claude --model 'opus[1m]'
}

locaterepos(){
    # find all git repos in the current directory and subdirectories
    find . -type d -name ".git" -exec dirname {} \; 2>/dev/null
}

awssso() {
    aws sso logout
    aws sso login --profile=ps-sas-admin
}

# set environment function
# use: "senv environmentFile"
senv() {
 source $ENVFILE_ROOT/"$1"
}

topen() {
    #open "https://console.twilio.com/user/accounts?q=$TWILIO_ACCOUNT_SID"
    open "https://www.twilio.com/console/projects/summary#:~:text=$TWILIO_ACCOUNT_SID"
}

tget() {
    local url="${1}"
    url="${url//\{AccountSid\}/$TWILIO_ACCOUNT_SID}"
    curl -G "$url" -u $TWILIO_ACCOUNT_SID:$TWILIO_AUTH_TOKEN
}

# tab completion for filenames
_envfile_complete() {
    local file
    for file in $ENVFILE_ROOT/"$2"*; do
        compadd $(basename "$file") # zsh
    done
}

compdef _envfile_complete senv
# <<< env management